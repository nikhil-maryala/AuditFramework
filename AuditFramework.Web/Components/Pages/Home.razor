@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>AuditFramework</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="hero">
            <h1>Welcome back@(string.IsNullOrEmpty(context.User.Identity?.Name) ? "" : ", " + context.User.Identity!.Name)</h1>
            <p class="text-muted">Manage your profile and security settings.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" href="/profile">My profile</a>
                <a class="btn btn-outline-secondary" href="/account/security">Security</a>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="hero hero-center">
            <h1>AuditFramework</h1>
            <p class="lead text-muted mb-4">Sign in to manage your profile and audit data.</p>
            <div class="d-flex gap-2 justify-content-center">
                <a class="btn btn-primary btn-lg px-4" href="/login">Sign in</a>
                <a class="btn btn-outline-secondary btn-lg px-4" href="/register">Create account</a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .hero {
        padding: 3rem 0;
    }
    .hero-center {
        max-width: 32rem;
        margin: 4rem auto;
        text-align: center;
    }
    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 0.75rem;
    }
</style>
