@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout AuthLayout
@inject IdentityApiClient Identity
@inject NavigationManager Nav

<PageTitle>Sign in</PageTitle>

<div class="auth-card">
    <h1 class="h3 mb-4 text-center">Sign in</h1>
    <EditForm Model="model" OnValidSubmit="Submit" FormName="login">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="model.Email" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText class="form-control" type="password" @bind-Value="model.Password" autocomplete="current-password" />
        </div>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger" role="alert">@error</div>
        }
        <button class="btn btn-primary w-100 mb-2" type="submit" disabled="@busy">Sign in</button>
        <a class="btn btn-outline-secondary w-100" href="/register">Create account</a>
    </EditForm>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private LoginModel model = new();
    private string? error;
    private bool busy;

    private async Task Submit()
    {
        busy = true;
        error = null;
        var (ok, err) = await Identity.LoginAsync(model.Email, model.Password);
        busy = false;
        if (!ok) { error = err ?? "Invalid email or password."; return; }
        Nav.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl);
    }

    public class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
